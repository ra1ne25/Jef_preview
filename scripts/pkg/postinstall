#!/bin/sh
# Выполняется инсталлятором после копирования файлов.
# Регистрирует приложение и QuickLook-расширения, сбрасывает кэш миниатюр.
APP="/Applications/JefPreview.app"
LSREG="/System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister"

# Регистрация в LaunchServices (UTI .jef + расширения)
"$LSREG" -f "$APP" 2>/dev/null || true

# pluginkit и qlmanage должны выполняться от имени залогиненного пользователя
CONSOLE_UID=$(stat -f %u /dev/console 2>/dev/null || echo "")
if [ -n "$CONSOLE_UID" ] && [ "$CONSOLE_UID" != "0" ]; then
  run_as_user() {
    launchctl asuser "$CONSOLE_UID" sudo -u "#$CONSOLE_UID" "$@" 2>/dev/null || true
  }
  run_as_user pluginkit -a "$APP/Contents/PlugIns/JefThumbnail.appex"
  run_as_user pluginkit -a "$APP/Contents/PlugIns/JefPreviewExt.appex"
  run_as_user pluginkit -e use -i com.flowdev.jefpreviwe.thumbnail
  run_as_user pluginkit -e use -i com.flowdev.jefpreviwe.preview
  run_as_user qlmanage -r
  run_as_user qlmanage -r cache
  # Перезапуск Finder, чтобы миниатюры обновились сразу
  run_as_user killall Finder
fi

exit 0
